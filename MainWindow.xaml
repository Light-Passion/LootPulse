<Window x:Class="LootPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LootPulse"
        mc:Ignorable="d"
        Title="LootPulse Overlay" 
        Height="650" Width="1000"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <!-- Converters -->
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <!-- Fluent Design Styles -->
        <Color x:Key="PoeOrange">#FF6124</Color>
        <Color x:Key="PoeGold">#E5B560</Color>
        <Color x:Key="BgDark">#181818</Color>
        <Color x:Key="BgPanel">#252525</Color>

        <!-- Custom ScrollBar Style for Sleek Modern Look -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Custom Buttons -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#FF6124"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E55018"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#323232"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#454545"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark Tab styling for the Commodities & Valuables panel -->
        <Style x:Key="DarkTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,2" Padding="4,6" Margin="0,0,18,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FF6124"/>
                                <Setter Property="Foreground" Value="#FF6124"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#282828" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF6124" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
            </Style.Resources>
            <Setter Property="Background" Value="#282828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="true">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition MinWidth="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}" Width="0"/>
                            </Grid.ColumnDefinitions>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   Grid.ColumnSpan="2"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                <Border x:Name="DropDownBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        CornerRadius="0,0,6,6"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}">
                                    <ScrollViewer x:Name="DropDownScrollViewer" CanContentScroll="True">
                                        <Grid x:Name="Grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="Canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0">
                                                <Rectangle x:Name="OpaqueRect" Fill="{Binding Background, ElementName=DropDownBorder}" Height="{Binding ActualHeight, ElementName=DropDownBorder}" Width="{Binding ActualWidth, ElementName=DropDownBorder}"/>
                                            </Canvas>
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton Grid.ColumnSpan="2"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow"
                                                      Grid.Column="1"
                                                      Data="M 0 0 L 3.5 3.5 L 7 0"
                                                      Fill="#CCCCCC"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#353535"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#FF6124"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#202020"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#FF6124"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#1A1A1A"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#333333"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#555555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              IsHitTestVisible="false"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="PART_Popup" Property="IsOpen" Value="false"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark context menu used by the "Load Build" dropdown button -->
        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF6124"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkMenuItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="3">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Border -->
    <Border x:Name="MainWindowBorder" CornerRadius="12" BorderBrush="#3D3D3D" BorderThickness="1.5" Background="#121212">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Titlebar / Header -->
                <RowDefinition Height="50"/>
                <!-- Main Content Area -->
                <RowDefinition Height="*"/>
                <!-- Statusbar -->
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- 1. Header/Titlebar (Draggable) -->
            <Grid Grid.Row="0" Background="#1A1A1A" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FF6124" Margin="0,0,10,0"/>
                    <TextBlock Text="LOOTPULSE DASHBOARD" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <Border CornerRadius="4" Background="#323232" Margin="15,0,0,0" Padding="6,2">
                        <TextBlock x:Name="OverlayModeText" Text="EDIT MODE" Foreground="#FF6124" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="[ Ctrl+Shift+O: HUD Mode | Ctrl+Shift+H: Show/Hide HUD ]" Foreground="#888888" FontSize="11" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button x:Name="SettingsToggleButton" Style="{StaticResource DarkButton}" Content="⚙ Settings" FontSize="12" Padding="10,5" VerticalAlignment="Center" Margin="0,0,8,0" Click="ToggleSettings_Click"/>
                    <Button Content="—" Foreground="Gray" FontSize="14" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Click="MinimizeButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Foreground="Gray" FontSize="14" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Red"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. Content Area -->
            <Grid Grid.Row="1" Margin="15" x:Name="MainContentGrid">

                <!-- ============ DASHBOARD VIEW ============ -->
                <Grid x:Name="DashboardView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top strip: Active State + Build Config -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Active State -->
                        <Border Grid.Column="0" Background="#1C1C1C" CornerRadius="8" Padding="15" Margin="0,0,15,0">
                            <StackPanel>
                                <TextBlock Text="ACTIVE STATE" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Border Background="#252525" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Character:" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock x:Name="CharNameText" Text="Exile" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Level:" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock x:Name="CharLevelText" Text="1" Foreground="#E5B560" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid>
                                            <TextBlock Text="Current Zone:" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock x:Name="CharZoneText" Text="Lioneye's Watch" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Build Config -->
                        <Border Grid.Column="1" Background="#1C1C1C" CornerRadius="8" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="BUILD CONFIG" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="BuildNameText" Text="No active build loaded" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="LoadBuildButton" Style="{StaticResource AccentButton}" Content="Load Build  ▾" Click="LoadBuildButton_Click">
                                                <Button.ContextMenu>
                                                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                        <MenuItem Header="Import PoB Share Code" Click="ImportPob_Click"/>
                                                        <MenuItem Header="Select .build File…" Click="SelectBuildFile_Click"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource AccentButton}" Content="Sync Economy &amp; Build" VerticalAlignment="Center" Margin="15,0,0,0" Click="SyncAll_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Economy Items Panel (tabbed) - full width -->
                    <Border Grid.Row="1" Background="#1C1C1C" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="COMMODITIES &amp; VALUABLES" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TabControl Grid.Row="1" Style="{StaticResource DarkTabControl}">
                                <!-- Tab 1: existing poe.ninja economy list -->
                                <TabItem Header="Currency Exchange Rates" Style="{StaticResource DarkTabItem}">
                                    <ListView x:Name="ItemListView" Background="Transparent" BorderThickness="0" Foreground="White" Margin="0,10,0,0" AlternationCount="2" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListViewItem">
                                                            <Border Background="{TemplateBinding Background}" Padding="8,7">
                                                                <GridViewRowPresenter Columns="{TemplateBinding GridView.ColumnCollection}"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="#202020"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A2A2A"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridView.ColumnHeaderContainerStyle>
                                                    <Style TargetType="GridViewColumnHeader">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#888888"/>
                                                        <Setter Property="FontSize" Value="10"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Padding" Value="8,0,8,8"/>
                                                        <Setter Property="BorderBrush" Value="#2C2C2C"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="GridViewColumnHeader">
                                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Bottom"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </GridView.ColumnHeaderContainerStyle>
                                                <GridViewColumn Width="340">
                                                    <GridViewColumn.HeaderTemplate>
                                                        <DataTemplate><TextBlock Text="NAME" HorizontalAlignment="Left"/></DataTemplate>
                                                    </GridViewColumn.HeaderTemplate>
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Width="160">
                                                    <GridViewColumn.HeaderTemplate>
                                                        <DataTemplate><TextBlock Text="CATEGORY" HorizontalAlignment="Left"/></DataTemplate>
                                                    </GridViewColumn.HeaderTemplate>
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Category}" Foreground="#888888"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Width="140">
                                                    <GridViewColumn.HeaderTemplate>
                                                        <DataTemplate><TextBlock Text="VALUE" HorizontalAlignment="Right"/></DataTemplate>
                                                    </GridViewColumn.HeaderTemplate>
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayValue}" Foreground="#E5B560" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </TabItem>

                                <!-- Tab 2: PoE2 trade site listings for build items -->
                                <TabItem Header="Trade Market" Style="{StaticResource DarkTabItem}">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Action bar -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button x:Name="ConnectTradeButton" Style="{StaticResource DarkButton}" Content="Connect Trade Account" Margin="0,0,10,0" Click="ConnectTradeAccount_Click"/>
                                            <Button x:Name="SearchTradeButton" Style="{StaticResource AccentButton}" Content="Search Trade Market" Click="SearchTradeMarket_Click"/>
                                            <TextBlock Text="Min. matched affixes:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="14,0,6,0"/>
                                            <TextBox x:Name="MinAffixMatchBox" Text="2" Width="36" Height="24" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                     Background="#1C1C1C" Foreground="White" BorderBrush="#3A3A3A"
                                                     ToolTip="A listing must match at least this many of the build's recommended affixes (0 = ignore affixes)."/>
                                            <TextBlock x:Name="TradeStatusText" Text="Cheapest listings you can equip now." Foreground="#888888" FontWeight="Normal" VerticalAlignment="Center" Margin="14,0,0,0"/>
                                        </StackPanel>

                                        <!-- Per-build-item groups, each with cheapest-5 -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="TradeGroupsList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#232323"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Style.Triggers>
                                                                        <!-- Build wants this item above the character's level: outline red (buy ahead). -->
                                                                        <DataTrigger Binding="{Binding IsAboveCharacterLevel}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#D9534F"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding ItemLabel}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                                                    <Border Grid.Column="1" Background="#1C1C1C" CornerRadius="4" Padding="6,2" Margin="8,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding LevelNote}" Foreground="#E5B560" FontSize="11"/>
                                                                    </Border>
                                                                    <Button Grid.Column="2" Style="{StaticResource DarkButton}" Content="Open on Trade Site" Click="OpenTradeSearch_Click" Tag="{Binding BrowserUrl}"/>
                                                                </Grid>

                                                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Listings}" Margin="0,8,0,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="110"/>
                                                                                    <ColumnDefinition Width="80"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="{Binding PriceText}" Foreground="#E5B560" FontWeight="Bold"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding NormalizedText}" Foreground="#8A8A8A" FontSize="11" VerticalAlignment="Center"
                                                                                           ToolTip="Approximate value in Chaos Orbs, used to rank cheapest across currencies."/>
                                                                                <TextBlock Grid.Column="2" Text="{Binding ItemLabel}" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Grid.Column="3" Text="{Binding Seller}" Foreground="#777777" FontSize="11"/>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="#777777" FontStyle="Italic" Margin="0,8,0,0"
                                                                           Visibility="{Binding HasListings, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ============ SETTINGS VIEW ============ -->
                <Border x:Name="SettingsView" Visibility="Collapsed" Background="#1C1C1C" CornerRadius="8" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">

                            <!-- Paths & Files -->
                            <TextBlock Text="PATHS &amp; FILES" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock Text="Client.txt Location" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="LogPathBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11"/>
                                <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseLog_Click"/>
                            </Grid>

                            <TextBlock Text="Base Filter (to merge)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="BaseFilterComboBox" Style="{StaticResource DarkComboBox}" SelectionChanged="BaseFilterComboBox_SelectionChanged" DisplayMemberPath="DisplayName"/>
                                <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseBaseFilter_Click"/>
                            </Grid>

                            <TextBlock Text="PoE2 Filter File Output Path" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FilterPathBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11"/>
                                <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseFilter_Click"/>
                            </Grid>

                            <!-- Economy Thresholds -->
                            <TextBlock Text="ECONOMY THRESHOLDS" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Tier 1 Threshold (Divine Orbs)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="Tier1Box" Width="120" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" Text="1.0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Tier 2 Threshold (Exalted Orbs)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="Tier2Box" Width="120" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" Text="1.0"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="EconomyHighlightsCheckBox" Content="Show Market Economy Highlights" Checked="EconomyHighlightsCheckBox_Changed" Unchecked="EconomyHighlightsCheckBox_Changed" Foreground="White" Margin="0,0,0,22"/>

                            <!-- Appearance -->
                            <TextBlock Text="APPEARANCE" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <Button Style="{StaticResource DarkButton}" Content="Customize Styles…" HorizontalAlignment="Left" Margin="0,0,0,22" Click="CustomizeStyles_Click"/>

                            <!-- HUD Overlay -->
                            <TextBlock Text="HUD OVERLAY" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <CheckBox x:Name="HudVisibleCheckBox" Content="Enable HUD Overlay" Checked="HudVisibleCheckBox_Changed" Unchecked="HudVisibleCheckBox_Changed" Foreground="White" Margin="0,0,0,12"/>

                            <TextBlock Text="Interactive Toggle Hotkey" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="HotkeyBox" Width="160" HorizontalAlignment="Left" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11" Text="Ctrl+Shift+O" IsReadOnly="True" Margin="0,0,0,12"/>

                            <TextBlock Text="Dashboard Opacity" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12" Width="480" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="EditOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.85" ValueChanged="OpacitySliders_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ElementName=EditOpacitySlider, Path=Value, StringFormat={}{0:P0}}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="HUD Overlay Opacity" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,16" Width="480" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="HudOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.30" ValueChanged="OpacitySliders_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ElementName=HudOpacitySlider, Path=Value, StringFormat={}{0:P0}}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Button Style="{StaticResource DarkButton}" Content="Reset HUD Size &amp; Position" HorizontalAlignment="Left" Click="ResetHudPosition_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 3. Status Bar -->
            <Grid Grid.Row="2" Background="#151515" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Grid.Column="1" Text="LootPulse Overlay" Foreground="#555555" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Grid.Column="2" Style="{StaticResource DarkButton}" Content="Exit Application" FontSize="11" Padding="10,3" VerticalAlignment="Center" Background="#4A1515" Foreground="#FF9999" Click="ExitButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
