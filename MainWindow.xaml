<Window x:Class="LootPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LootPulse"
        mc:Ignorable="d"
        Title="LootPulse Overlay" 
        Height="650" Width="1000"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <!-- Fluent Design Styles -->
        <Color x:Key="PoeOrange">#FF6124</Color>
        <Color x:Key="PoeGold">#E5B560</Color>
        <Color x:Key="BgDark">#181818</Color>
        <Color x:Key="BgPanel">#252525</Color>

        <!-- Custom ScrollBar Style for Sleek Modern Look -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Custom Buttons -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#FF6124"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E55018"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#323232"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#454545"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#282828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#282828" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF6124" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
            </Style.Resources>
        </Style>
    </Window.Resources>

    <!-- Main Window Border -->
    <Border x:Name="MainWindowBorder" CornerRadius="12" BorderBrush="#3D3D3D" BorderThickness="1.5" Background="#F2121212">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Titlebar / Header -->
                <RowDefinition Height="50"/>
                <!-- Main Content Area -->
                <RowDefinition Height="*"/>
                <!-- Statusbar -->
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- 1. Header/Titlebar (Draggable) -->
            <Grid Grid.Row="0" Background="#1A1A1A" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FF6124" Margin="0,0,10,0"/>
                    <TextBlock Text="LOOTPULSE DASHBOARD" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <Border CornerRadius="4" Background="#323232" Margin="15,0,0,0" Padding="6,2">
                        <TextBlock x:Name="OverlayModeText" Text="EDIT MODE" Foreground="#FF6124" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="[ Ctrl+Shift+O: HUD Mode | Ctrl+Shift+H: Show/Hide HUD ]" Foreground="#888888" FontSize="11" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Content="—" Foreground="Gray" FontSize="14" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Click="MinimizeButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Foreground="Gray" FontSize="14" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Red"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. Content Area -->
            <Grid Grid.Row="1" Margin="15" x:Name="MainContentGrid">
                <Grid.ColumnDefinitions>
                    <!-- Sidebar: Info & Settings -->
                    <ColumnDefinition Width="320"/>
                    <!-- Main panel: Economy Monitoring -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Panel -->
                <Border Grid.Column="0" Background="#1C1C1C" CornerRadius="8" Padding="15" Margin="0,0,15,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Character Info Section -->
                            <TextBlock Text="ACTIVE STATE" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="0,0,0,18">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Character:" Foreground="#AAAAAA" FontSize="12"/>
                                        <TextBlock x:Name="CharNameText" Text="Exile" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Level:" Foreground="#AAAAAA" FontSize="12"/>
                                        <TextBlock x:Name="CharLevelText" Text="1" Foreground="#E5B560" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Current Zone:" Foreground="#AAAAAA" FontSize="12"/>
                                        <TextBlock x:Name="CharZoneText" Text="Lioneye's Watch" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Build Sync Section -->
                            <TextBlock Text="BUILD CONFIG" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock x:Name="BuildNameText" Text="No active build loaded" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                    
                                    <Button Style="{StaticResource AccentButton}" Content="Import PoB Share Code" Margin="0,0,0,8" Click="ImportPob_Click"/>
                                    <Button Style="{StaticResource DarkButton}" Content="Select .build File" Click="SelectBuildFile_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Settings / Paths Section -->
                            <TextBlock Text="DIRECTORIES &amp; SETTINGS" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Margin="0,0,0,5">
                                <TextBlock Text="Client.txt Location" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LogPathBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11"/>
                                    <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseLog_Click"/>
                                </Grid>

                                <TextBlock Text="Base Filter (to merge)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="BaseFilterComboBox" Style="{StaticResource DarkComboBox}" SelectionChanged="BaseFilterComboBox_SelectionChanged" DisplayMemberPath="DisplayName"/>
                                    <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseBaseFilter_Click"/>
                                </Grid>

                                <TextBlock Text="PoE2 Filter File Output Path" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FilterPathBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11"/>
                                    <Button Grid.Column="1" Style="{StaticResource DarkButton}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseFilter_Click"/>
                                </Grid>

                                <TextBlock Text="Interactive Toggle Hotkey" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="HotkeyBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11" Text="Ctrl+Shift+O" IsReadOnly="True" Margin="0,0,0,10"/>

                                <CheckBox x:Name="HudVisibleCheckBox" Content="Enable HUD Overlay" Checked="HudVisibleCheckBox_Changed" Unchecked="HudVisibleCheckBox_Changed" Foreground="White" Margin="0,5,0,10"/>

                                <TextBlock Text="Edit Mode Dashboard Opacity" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="EditOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.85" ValueChanged="OpacitySliders_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ElementName=EditOpacitySlider, Path=Value, StringFormat={}{0:F2}}" Foreground="White" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="HUD Overlay Opacity" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="HudOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.30" ValueChanged="OpacitySliders_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ElementName=HudOpacitySlider, Path=Value, StringFormat={}{0:F2}}" Foreground="White" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <Button Style="{StaticResource DarkButton}" Content="Reset HUD Size &amp; Position" Margin="0,5,0,0" Click="ResetHudPosition_Click"/>
                                <Button Style="{StaticResource DarkButton}" Content="Exit Application" Margin="0,15,0,0" Background="#4A1515" Foreground="#FF9999" Click="ExitButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Economy Monitoring Main Panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Control bar -->
                    <Border Grid.Row="0" Background="#1C1C1C" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Tier 1 Threshold (Divine Orbs)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="Tier1Box" Width="100" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" Text="1.0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Tier 2 Threshold (Exalted Orbs)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="Tier2Box" Width="100" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" Text="1.0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Style="{StaticResource DarkButton}" Content="Customize Styles" Margin="0,0,10,0" Click="CustomizeStyles_Click"/>
                                <Button Style="{StaticResource AccentButton}" Content="Sync Economy &amp; Build" Click="SyncAll_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Economy Items List -->
                    <Border Grid.Row="1" Background="#1C1C1C" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="COMMODITIES &amp; VALUABLES" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                            <ListView Grid.Row="1" x:Name="ItemListView" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Padding" Value="5"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2A2A"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Name" Width="250">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Category" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Category}" Foreground="#888888"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Value" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayValue}" Foreground="#E5B560" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 3. Status Bar -->
            <Grid Grid.Row="2" Background="#151515" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="LootPulse Overlay v1.0.0" Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>
</Window>
