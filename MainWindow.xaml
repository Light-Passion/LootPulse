<Window x:Class="LootPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LootPulse"
        xmlns:controls="clr-namespace:LootPulse.Controls"
        mc:Ignorable="d"
        Title="LootPulse Overlay" 
        Height="650" Width="1000"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <!-- Converters -->
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Window.Resources>

    <!-- Main Window Border -->
    <Border x:Name="MainWindowBorder" CornerRadius="12" BorderBrush="#3D3D3D" BorderThickness="1.5" Background="#121212">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Titlebar / Header -->
                <RowDefinition Height="50"/>
                <!-- Main Content Area -->
                <RowDefinition Height="*"/>
                <!-- Statusbar -->
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- 1. Header/Titlebar (Draggable) -->
            <Grid Grid.Row="0" Background="#1A1A1A" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FF6124" Margin="0,0,10,0"/>
                    <TextBlock Text="LOOTPULSE" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <!-- Market Pulse Graph — live EKG heartbeat line -->
                    <controls:MarketPulseGraph x:Name="HeaderPulseGraph"
                                                Width="200" Height="24"
                                                Margin="12,0,12,0"
                                                VerticalAlignment="Center"/>
                    <Border CornerRadius="4" Background="#323232" Margin="0,0,0,0" Padding="6,2">
                        <TextBlock x:Name="OverlayModeText" Text="EDIT MODE" Foreground="#FF6124" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="[ Ctrl+Shift+O: HUD Mode | Ctrl+Shift+H: Show/Hide HUD ]" Foreground="#888888" FontSize="11" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button x:Name="SettingsToggleButton" Style="{StaticResource BtnSecondary}" Content="⚙ Settings" FontSize="12" Padding="10,5" VerticalAlignment="Center" Margin="0,0,8,0" Click="ToggleSettings_Click"/>
                    <Button Content="—" Foreground="Gray" FontSize="14" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Click="MinimizeButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Foreground="Gray" FontSize="14" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Red"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. Content Area -->
            <Grid Grid.Row="1" Margin="15" x:Name="MainContentGrid">

                <!-- ============ DASHBOARD VIEW ============ -->
                <Grid x:Name="DashboardView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top strip: Active State + Build Config -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Active State -->
                        <Border Grid.Column="0" Background="#1C1C1C" CornerRadius="8" Padding="15" Margin="0,0,15,0">
                            <StackPanel>
                                <TextBlock Text="ACTIVE STATE" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Border Background="#252525" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Character:" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock x:Name="CharNameText" Text="Exile" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Level:" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock x:Name="CharLevelText" Text="1" Foreground="#E5B560" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid>
                                            <TextBlock Text="Current Zone:" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock x:Name="CharZoneText" Text="Lioneye's Watch" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Build Config -->
                        <Border Grid.Column="1" Background="#1C1C1C" CornerRadius="8" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="BUILD CONFIG" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="SelectedFilterNameText" Text="Base Filter: None (LootPulse Highlights Only)" Foreground="#FF6124" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="BuildNameText" Text="No active build loaded" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="LoadBuildButton" Style="{StaticResource BtnPrimary}" Content="Load Build  ▾" Click="LoadBuildButton_Click" Margin="0,0,8,0" />
                                            <Button x:Name="BaseFilterButton" Style="{StaticResource BtnPrimary}" Content="Select Base Filter  ▾" Click="BaseFilterButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource BtnPrimary}" Content="Sync Economy &amp; Build" VerticalAlignment="Center" Margin="15,0,0,0" Click="SyncAll_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Economy Items Panel (tabbed) - full width -->
                    <Border Grid.Row="1" Background="#1C1C1C" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="COMMODITIES &amp; VALUABLES" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TabControl Grid.Row="1" Style="{StaticResource PulseTabControl}" SelectionChanged="CommoditiesTab_SelectionChanged">
                                <!-- Tab 1: existing poe.ninja economy list -->
                                <TabItem Header="Currency Exchange Rates" Style="{StaticResource PulseTabItem}">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Category Filter Dropdown -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Filter by Category:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11" FontWeight="SemiBold"/>
                                            <ComboBox x:Name="EconomyCategoryComboBox" Width="180" Height="26" Style="{StaticResource LootComboBox}" SelectionChanged="EconomyCategoryComboBox_SelectionChanged"/>
                                        </StackPanel>

                                        <ListView Grid.Row="1" x:Name="ItemListView" Background="Transparent" BorderThickness="0" Foreground="White" AlternationCount="2" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListViewItem">
                                                                <Border Background="{TemplateBinding Background}" Padding="8,7">
                                                                    <GridViewRowPresenter Columns="{TemplateBinding GridView.ColumnCollection}"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                            <Setter Property="Background" Value="#202020"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2A2A2A"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.View>
                                                <GridView>
                                                    <GridView.ColumnHeaderContainerStyle>
                                                        <Style TargetType="GridViewColumnHeader">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="#888888"/>
                                                            <Setter Property="FontSize" Value="10"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            <Setter Property="Padding" Value="8,0,8,8"/>
                                                            <Setter Property="BorderBrush" Value="#2C2C2C"/>
                                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="GridViewColumnHeader">
                                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Bottom"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </GridView.ColumnHeaderContainerStyle>
                                                    <GridViewColumn Width="340">
                                                        <GridViewColumn.HeaderTemplate>
                                                            <DataTemplate><TextBlock Text="NAME" HorizontalAlignment="Left"/></DataTemplate>
                                                        </GridViewColumn.HeaderTemplate>
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Width="160">
                                                        <GridViewColumn.HeaderTemplate>
                                                            <DataTemplate><TextBlock Text="CATEGORY" HorizontalAlignment="Left"/></DataTemplate>
                                                        </GridViewColumn.HeaderTemplate>
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Category}" Foreground="#888888"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Width="140">
                                                        <GridViewColumn.HeaderTemplate>
                                                            <DataTemplate><TextBlock Text="VALUE" HorizontalAlignment="Right"/></DataTemplate>
                                                        </GridViewColumn.HeaderTemplate>
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayValue}" Foreground="#E5B560" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Grid>
                                </TabItem>

                                <!-- Tab 2: PoE2 trade site listings for build items -->
                                <TabItem x:Name="TradeMarketTab" Header="Trade Market" Style="{StaticResource PulseTabItem}">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Action bar -->
                                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="ConnectTradeButton" Style="{StaticResource BtnSecondary}" Content="Connect Trade Account" Margin="0,0,10,0" Click="ConnectTradeAccount_Click"/>
                                                <Button x:Name="SearchTradeButton" Style="{StaticResource BtnPrimary}" Content="Search Trade Market" Click="SearchTradeMarket_Click"/>
                                                <StackPanel x:Name="MinMatchedPanel" Orientation="Horizontal">
                                                    <TextBlock Text="Min. matched affixes:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="14,0,6,0"/>
                                                    <TextBox x:Name="MinAffixMatchBox" Text="2" Width="36" Height="24" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                             Background="#1C1C1C" Foreground="White" BorderBrush="#3A3A3A"
                                                             ToolTip="A listing must match at least this many of the build's recommended affixes (0 = ignore affixes)."/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="Mode:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <RadioButton x:Name="CheapestModeRadio" GroupName="TradeMode" Content="Cheapest (league start)" Foreground="#DDDDDD" VerticalAlignment="Center" IsChecked="True"
                                                             Checked="TradeMode_Changed" ToolTip="Show the genuine cheapest listing that fills each slot."/>
                                                <RadioButton x:Name="BestInSlotModeRadio" GroupName="TradeMode" Content="Best-in-slot (reroll)" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="14,0,0,0"
                                                             Checked="TradeMode_Changed" ToolTip="Within a per-item budget, show the best roll by per-slot affix weighting."/>
                                                <StackPanel x:Name="BudgetPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="16,0,0,0">
                                                    <TextBlock Text="Budget / item (div):" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBox x:Name="BudgetDivineBox" Text="1" Width="50" Height="24" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                             Background="#1C1C1C" Foreground="White" BorderBrush="#3A3A3A"
                                                             ToolTip="Maximum spend per item, in Divine Orbs. Listings above this are excluded in Best-in-slot mode."/>
                                                    <TextBlock Text="site opens price-sorted — click Sum to match" Foreground="#888888" FontStyle="Italic" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"
                                                               ToolTip="LootPulse ranks by weighted Sum, but the trade site's link opens sorted by price. Click the Sum column on the site to match this order."/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock x:Name="TradeStatusText" Text="Cheapest listings you can equip now." Foreground="#888888" FontWeight="Normal" Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <!-- Per-build-item groups, each with cheapest-5 -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="TradeGroupsList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#232323"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Style.Triggers>
                                                                        <!-- Build wants this item above the character's level: outline red (buy ahead). -->
                                                                        <DataTrigger Binding="{Binding IsAboveCharacterLevel}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#D9534F"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding ItemLabel}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                                                    <Border Grid.Column="1" Background="#1C1C1C" CornerRadius="4" Padding="6,2" Margin="8,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding LevelNote}" Foreground="#E5B560" FontSize="11"/>
                                                                    </Border>
                                                                    <Button Grid.Column="2" Style="{StaticResource BtnSecondary}" Content="Open on Trade Site" Click="OpenTradeSearch_Click" Tag="{Binding BrowserUrl}"/>
                                                                </Grid>

                                                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Listings}" Margin="0,8,0,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="110"/>
                                                                                    <ColumnDefinition Width="80"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="{Binding PriceText}" Foreground="#E5B560" FontWeight="Bold"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding NormalizedText}" Foreground="#8A8A8A" FontSize="11" VerticalAlignment="Center"
                                                                                           ToolTip="Approximate value in Exalted Orbs (Divine for larger values), used to rank cheapest across currencies."/>
                                                                                <TextBlock Grid.Column="2" Text="{Binding ItemLabel}" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Grid.Column="3" Text="{Binding Seller}" Foreground="#777777" FontSize="11"/>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="#777777" FontStyle="Italic" Margin="0,8,0,0"
                                                                           Visibility="{Binding HasListings, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </TabItem>

                                <!-- Tab 3: Custom weights for recommended build affixes -->
                                <TabItem x:Name="AffixWeightsTab" Header="Affix Weights" Style="{StaticResource PulseTabItem}" Visibility="Collapsed">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Assign importance to recommended affixes for Best-in-Slot mode. 'Required' affixes must be present on the item." 
                                                   Foreground="#888888" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="AffixWeightsControl">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#232323" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                                                        <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                                                        <Border Background="#1C1C1C" CornerRadius="4" Padding="6,2" Margin="8,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding SlotId}" Foreground="#E5B560" FontSize="11"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <ItemsControl ItemsSource="{Binding Affixes}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="180"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Text="{Binding Text}" Foreground="#DDDDDD" VerticalAlignment="Center" FontSize="12" Margin="0,0,10,0" TextWrapping="Wrap"/>
                                                                                <ComboBox Grid.Column="1" Style="{StaticResource LootComboBox}" Height="24"
                                                            ItemsSource="{Binding Source={x:Static local:MainWindow.ImportanceOptions}}"
                                                            SelectedValue="{Binding Importance, Mode=TwoWay}"
                                                            SelectedValuePath="Value"
                                                            DisplayMemberPath="Name"
                                                            SelectionChanged="AffixImportance_SelectionChanged"/>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </TabItem>

                                <!-- Tab 4: ground-drop appearance / style editor -->
                                <TabItem x:Name="FilterStylesTab" Header="Filter Styles" Style="{StaticResource PulseTabItem}">
                                    <ContentControl x:Name="FilterStylesHost"/>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ============ SETTINGS VIEW ============ -->
                <Border x:Name="SettingsView" Visibility="Collapsed" Background="#1C1C1C" CornerRadius="8" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">

                            <!-- Paths & Files -->
                            <TextBlock Text="PATHS &amp; FILES" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock Text="Client.txt Location" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="LogPathBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11"/>
                                <Button Grid.Column="1" Style="{StaticResource BtnSecondary}" Content="Browse" Padding="8,4" Margin="5,0,0,0" Click="BrowseLog_Click"/>
                            </Grid>


                            <TextBlock Text="PoE2 Filter File Output Path" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FilterPathBox" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11"/>
                            </Grid>

                            <!-- Metadata & Data Updates -->
                            <TextBlock Text="METADATA &amp; DATA UPDATES" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                <Button x:Name="UpdateMetadataButton" Style="{StaticResource BtnPrimary}" Content="Update Base Items &amp; Currencies" Click="UpdateMetadata_Click" Padding="15,6" Margin="0,0,12,0"/>
                                <TextBlock x:Name="MetadataStatusText" Text="Status: Local database loaded" Foreground="#AAAAAA" VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" MaxWidth="500"/>
                            </StackPanel>

                            <!-- Economy Thresholds (Disabled for now) -->
                            <StackPanel Visibility="Collapsed">
                                <TextBlock Text="ECONOMY THRESHOLDS" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Tier 1 Threshold (Divine Orbs)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="Tier1Box" Width="120" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" Text="1.0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Tier 2 Threshold (Exalted Orbs)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="Tier2Box" Width="120" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" Text="1.0"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox x:Name="EconomyHighlightsCheckBox" Content="Show Market Economy Highlights" Checked="EconomyHighlightsCheckBox_Changed" Unchecked="EconomyHighlightsCheckBox_Changed" Foreground="White" Margin="0,0,0,22"/>
                            </StackPanel>

                            <!-- HUD Overlay -->
                            <TextBlock Text="HUD OVERLAY" Foreground="#FF6124" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <CheckBox x:Name="HudVisibleCheckBox" Content="Enable HUD Overlay" Checked="HudVisibleCheckBox_Changed" Unchecked="HudVisibleCheckBox_Changed" Foreground="White" Margin="0,0,0,12"/>

                            <TextBlock Text="Interactive Toggle Hotkey" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="HotkeyBox" Width="160" HorizontalAlignment="Left" Background="#282828" Foreground="White" BorderThickness="0" Padding="8,5" FontSize="11" Text="Ctrl+Shift+O" IsReadOnly="True" Margin="0,0,0,12"/>

                            <TextBlock Text="Dashboard Opacity" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12" Width="480" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="EditOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.85" ValueChanged="OpacitySliders_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ElementName=EditOpacitySlider, Path=Value, StringFormat={}{0:P0}}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="HUD Overlay Opacity" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,16" Width="480" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="HudOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.30" ValueChanged="OpacitySliders_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ElementName=HudOpacitySlider, Path=Value, StringFormat={}{0:P0}}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Button Style="{StaticResource BtnSecondary}" Content="Reset HUD Size &amp; Position" HorizontalAlignment="Left" Click="ResetHudPosition_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 3. Status Bar -->
            <Grid Grid.Row="2" Background="#151515" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Grid.Column="1" Text="LootPulse Overlay" Foreground="#555555" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnPrimary}" Content="Save Settings" FontSize="11" Padding="10,3" Margin="0,0,8,0" Click="SaveSettings_Click"/>
                    <Button Style="{StaticResource BtnSecondary}" Content="Exit Application" FontSize="11" Padding="10,3" Background="#4A1515" Foreground="#FF9999" Click="ExitButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
