<Application x:Class="LootPulse.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LootPulse"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/LootPulse;component/Styles/Theme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/LootPulse;component/Styles/Typography.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/LootPulse;component/Styles/Controls.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/LootPulse;component/Styles/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
