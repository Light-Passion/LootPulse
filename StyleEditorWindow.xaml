<Window x:Class="LootPulse.StyleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LootPulse Style Editor" Height="620" Width="680"
        MinHeight="500" MinWidth="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Modern ScrollViewer style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Base Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Base Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF6124"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FF6124"/>
            <Setter Property="BorderBrush" Value="#FF6124"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#FF7A47"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E05018"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#990000"/>
            <Setter Property="BorderBrush" Value="#BB0000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#BB2222"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#770000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF6124"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#222222" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF6124" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
            </Style.Resources>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="true">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition MinWidth="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}" Width="0"/>
                            </Grid.ColumnDefinitions>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   Grid.ColumnSpan="2"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                <Border x:Name="DropDownBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        CornerRadius="0,0,6,6"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}">
                                    <ScrollViewer x:Name="DropDownScrollViewer" CanContentScroll="True">
                                        <Grid x:Name="Grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="Canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0">
                                                <Rectangle x:Name="OpaqueRect" Fill="{Binding Background, ElementName=DropDownBorder}" Height="{Binding ActualHeight, ElementName=DropDownBorder}" Width="{Binding ActualWidth, ElementName=DropDownBorder}"/>
                                            </Canvas>
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton Grid.ColumnSpan="2"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow"
                                                      Grid.Column="1"
                                                      Data="M 0 0 L 3.5 3.5 L 7 0"
                                                      Fill="#CCCCCC"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#353535"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#FF6124"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#202020"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#FF6124"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#1A1A1A"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#333333"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#555555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              IsHitTestVisible="false"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="PART_Popup" Property="IsOpen" Value="false"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6124"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Outer Window Border with Rounded Corners -->
    <Border BorderBrush="#444444" BorderThickness="1" Background="#E6151515" CornerRadius="12">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/> <!-- Drag Titlebar -->
                <RowDefinition Height="Auto"/> <!-- Preset Selector -->
                <RowDefinition Height="*"/> <!-- Main Editor Content -->
                <RowDefinition Height="Auto"/> <!-- Live Preview -->
                <RowDefinition Height="50"/> <!-- Dialog Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Drag Titlebar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LootPulse Style Editor" Foreground="White" FontWeight="Bold" FontSize="14" 
                               FontFamily="Segoe UI Variable Display, Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Close_Click" Background="Transparent" Foreground="#888888" 
                        BorderBrush="Transparent" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Style="{StaticResource ModernButton}" Width="30" Height="30" Padding="0"/>
            </Grid>

            <!-- Theme Presets Top Bar -->
            <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,5,0,10" BorderBrush="#2D2D2D" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Label Grid.Column="0" Content="Preset:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Grid.Column="1" x:Name="PresetComboBox" SelectionChanged="PresetComboBox_SelectionChanged" Height="26" VerticalAlignment="Center"/>
                    
                    <Label Grid.Column="2" Content="Name:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <TextBox Grid.Column="3" x:Name="PresetNameTextBox" Height="26" VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button Content="Save Preset" Click="SavePreset_Click" Margin="0,0,5,0" Height="26" Style="{StaticResource ModernButton}"/>
                        <Button Content="Delete Preset" Click="DeletePreset_Click" Margin="0,0,5,0" Height="26" Style="{StaticResource DangerButton}"/>
                        <Button Content="Reset Defaults" Click="ResetDefaults_Click" Height="26" Style="{StaticResource ModernButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Editor Content Area -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Category Tab Selector -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Category to edit:" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="1" x:Name="CategorySelector" Height="28" SelectionChanged="CategorySelector_SelectionChanged">
                        <ComboBoxItem Content="Uniques" Tag="Uniques" IsSelected="True"/>
                        <ComboBoxItem Content="Skill Gems" Tag="Gems"/>
                        <ComboBoxItem Content="Progression Bases (Leveling/Zone)" Tag="ProgressionBases"/>
                        <ComboBoxItem Content="Tier 1 Economy Items" Tag="EconomyTier1"/>
                        <ComboBoxItem Content="Tier 2 Economy Items" Tag="EconomyTier2"/>
                    </ComboBox>
                </Grid>

                <!-- Configuration Cards Scroll Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ControlsContainer" Margin="0,0,5,0">
                        <CheckBox x:Name="CategoryEnabledCheckBox" Content="Enable Highlighting for this category" 
                                  Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10" Checked="ControlChanged" Unchecked="ControlChanged"/>
                        
                        <!-- Ground Visuals Card -->
                        <GroupBox Header="Ground Label Colors &amp; Size" Foreground="#FF6124" BorderBrush="#333333" Margin="0,0,0,12" Padding="10">
                            <StackPanel>
                                <!-- Text Color -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Text Color (Hex):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="TextColorTextBox" Height="26" TextChanged="ColorTextBox_TextChanged" MaxLength="9"/>
                                    <!-- Color Button & Swatch Popup -->
                                    <Button Grid.Column="2" x:Name="TextColorBtn" Click="ColorBtn_Click" Width="26" Height="26" BorderThickness="1" BorderBrush="#555555">
                                        <Button.Background>
                                            <SolidColorBrush Color="White"/>
                                        </Button.Background>
                                    </Button>
                                    <Popup x:Name="TextColorPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=TextColorBtn}" Placement="Bottom">
                                        <Border Background="#202020" BorderBrush="#FF6124" BorderThickness="1.5" Padding="10" CornerRadius="8">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="TextColorCanvas" Grid.Column="0" Width="200" Height="140" CornerRadius="4" BorderBrush="#444444" BorderThickness="1" ClipToBounds="True" Cursor="Cross"
                                                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown" MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseLeftButtonUp" Tag="TextColor">
                                                        <Grid x:Name="TextColorCanvasGrid" Background="Red">
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                        <GradientStop Color="#00000000" Offset="0"/>
                                                                        <GradientStop Color="#FF000000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas IsHitTestVisible="False">
                                                                <Ellipse x:Name="TextColorCursor" Width="8" Height="8" Margin="-4,-4,0,0" Stroke="White" StrokeThickness="1.5" Fill="Transparent">
                                                                    <Ellipse.Effect>
                                                                        <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Color="Black" Opacity="0.8"/>
                                                                    </Ellipse.Effect>
                                                                </Ellipse>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                    <Border x:Name="TextColorHueBar" Grid.Column="1" Width="18" Height="140" Margin="10,0,0,0" CornerRadius="3" BorderBrush="#444444" BorderThickness="1" ClipToBounds="True" Cursor="Hand"
                                                            MouseLeftButtonDown="HueBar_MouseLeftButtonDown" MouseMove="HueBar_MouseMove" MouseLeftButtonUp="HueBar_MouseLeftButtonUp" Tag="TextColor">
                                                        <Grid>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                        <GradientStop Color="#FFFF0000" Offset="0"/>
                                                                        <GradientStop Color="#FFFFFF00" Offset="0.167"/>
                                                                        <GradientStop Color="#FF00FF00" Offset="0.333"/>
                                                                        <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                                                                        <GradientStop Color="#FF0000FF" Offset="0.667"/>
                                                                        <GradientStop Color="#FFFF00FF" Offset="0.833"/>
                                                                        <GradientStop Color="#FFFF0000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas IsHitTestVisible="False">
                                                                <Rectangle x:Name="TextColorHueCursor" Width="22" Height="4" Margin="-2,-2,0,0" Fill="White" Stroke="Black" StrokeThickness="0.5"/>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <Button Content="👁️‍🗨️ Screen Picker" Click="ScreenPicker_Click" Tag="TextColor"
                                                        Height="24" Margin="0,0,0,8" Style="{StaticResource ModernButton}" FontSize="10" Padding="5,2"/>
                                                <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,0,0,8"/>
                                                <TextBlock Text="Swatches" Foreground="#888888" FontSize="10" Margin="0,0,0,6" FontWeight="SemiBold" FontFamily="Segoe UI Variable Small"/>
                                                <UniformGrid Rows="4" Columns="6" Width="168" Height="112" x:Name="TextColorGrid"/>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    
                                    <Label Grid.Column="4" Content="Opacity:" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="4" x:Name="TextOpacitySlider" Minimum="0" Maximum="255" Value="255" 
                                            Margin="60,0,0,0" VerticalAlignment="Center" ValueChanged="OpacitySlider_ValueChanged"/>
                                </Grid>

                                <!-- Border Color -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Border Color (Hex):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="BorderColorTextBox" Height="26" TextChanged="ColorTextBox_TextChanged" MaxLength="9"/>
                                    <Button Grid.Column="2" x:Name="BorderColorBtn" Click="ColorBtn_Click" Width="26" Height="26" BorderThickness="1" BorderBrush="#555555"/>
                                    <Popup x:Name="BorderColorPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=BorderColorBtn}" Placement="Bottom">
                                        <Border Background="#202020" BorderBrush="#FF6124" BorderThickness="1.5" Padding="10" CornerRadius="8">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="BorderColorCanvas" Grid.Column="0" Width="200" Height="140" CornerRadius="4" BorderBrush="#444444" BorderThickness="1" ClipToBounds="True" Cursor="Cross"
                                                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown" MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseLeftButtonUp" Tag="BorderColor">
                                                        <Grid x:Name="BorderColorCanvasGrid" Background="Red">
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                        <GradientStop Color="#00000000" Offset="0"/>
                                                                        <GradientStop Color="#FF000000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas IsHitTestVisible="False">
                                                                <Ellipse x:Name="BorderColorCursor" Width="8" Height="8" Margin="-4,-4,0,0" Stroke="White" StrokeThickness="1.5" Fill="Transparent">
                                                                    <Ellipse.Effect>
                                                                        <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Color="Black" Opacity="0.8"/>
                                                                    </Ellipse.Effect>
                                                                </Ellipse>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                    <Border x:Name="BorderColorHueBar" Grid.Column="1" Width="18" Height="140" Margin="10,0,0,0" CornerRadius="3" BorderBrush="#444444" BorderThickness="1" ClipToBounds="True" Cursor="Hand"
                                                            MouseLeftButtonDown="HueBar_MouseLeftButtonDown" MouseMove="HueBar_MouseMove" MouseLeftButtonUp="HueBar_MouseLeftButtonUp" Tag="BorderColor">
                                                        <Grid>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                        <GradientStop Color="#FFFF0000" Offset="0"/>
                                                                        <GradientStop Color="#FFFFFF00" Offset="0.167"/>
                                                                        <GradientStop Color="#FF00FF00" Offset="0.333"/>
                                                                        <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                                                                        <GradientStop Color="#FF0000FF" Offset="0.667"/>
                                                                        <GradientStop Color="#FFFF00FF" Offset="0.833"/>
                                                                        <GradientStop Color="#FFFF0000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas IsHitTestVisible="False">
                                                                <Rectangle x:Name="BorderColorHueCursor" Width="22" Height="4" Margin="-2,-2,0,0" Fill="White" Stroke="Black" StrokeThickness="0.5"/>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <Button Content="👁️‍🗨️ Screen Picker" Click="ScreenPicker_Click" Tag="BorderColor"
                                                        Height="24" Margin="0,0,0,8" Style="{StaticResource ModernButton}" FontSize="10" Padding="5,2"/>
                                                <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,0,0,8"/>
                                                <TextBlock Text="Swatches" Foreground="#888888" FontSize="10" Margin="0,0,0,6" FontWeight="SemiBold" FontFamily="Segoe UI Variable Small"/>
                                                <UniformGrid Rows="4" Columns="6" Width="168" Height="112" x:Name="BorderColorGrid"/>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    
                                    <Label Grid.Column="4" Content="Opacity:" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="4" x:Name="BorderOpacitySlider" Minimum="0" Maximum="255" Value="255" 
                                            Margin="60,0,0,0" VerticalAlignment="Center" ValueChanged="OpacitySlider_ValueChanged"/>
                                </Grid>

                                <!-- Background Color -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Background (Hex):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="BackgroundColorTextBox" Height="26" TextChanged="ColorTextBox_TextChanged" MaxLength="9"/>
                                    <Button Grid.Column="2" x:Name="BackgroundColorBtn" Click="ColorBtn_Click" Width="26" Height="26" BorderThickness="1" BorderBrush="#555555"/>
                                    <Popup x:Name="BackgroundColorPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=BackgroundColorBtn}" Placement="Bottom">
                                        <Border Background="#202020" BorderBrush="#FF6124" BorderThickness="1.5" Padding="10" CornerRadius="8">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="BackgroundColorCanvas" Grid.Column="0" Width="200" Height="140" CornerRadius="4" BorderBrush="#444444" BorderThickness="1" ClipToBounds="True" Cursor="Cross"
                                                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown" MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseLeftButtonUp" Tag="BackgroundColor">
                                                        <Grid x:Name="BackgroundColorCanvasGrid" Background="Red">
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                        <GradientStop Color="#00000000" Offset="0"/>
                                                                        <GradientStop Color="#FF000000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas IsHitTestVisible="False">
                                                                <Ellipse x:Name="BackgroundColorCursor" Width="8" Height="8" Margin="-4,-4,0,0" Stroke="White" StrokeThickness="1.5" Fill="Transparent">
                                                                    <Ellipse.Effect>
                                                                        <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Color="Black" Opacity="0.8"/>
                                                                    </Ellipse.Effect>
                                                                </Ellipse>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                    <Border x:Name="BackgroundColorHueBar" Grid.Column="1" Width="18" Height="140" Margin="10,0,0,0" CornerRadius="3" BorderBrush="#444444" BorderThickness="1" ClipToBounds="True" Cursor="Hand"
                                                            MouseLeftButtonDown="HueBar_MouseLeftButtonDown" MouseMove="HueBar_MouseMove" MouseLeftButtonUp="HueBar_MouseLeftButtonUp" Tag="BackgroundColor">
                                                        <Grid>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                        <GradientStop Color="#FFFF0000" Offset="0"/>
                                                                        <GradientStop Color="#FFFFFF00" Offset="0.167"/>
                                                                        <GradientStop Color="#FF00FF00" Offset="0.333"/>
                                                                        <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                                                                        <GradientStop Color="#FF0000FF" Offset="0.667"/>
                                                                        <GradientStop Color="#FFFF00FF" Offset="0.833"/>
                                                                        <GradientStop Color="#FFFF0000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas IsHitTestVisible="False">
                                                                <Rectangle x:Name="BackgroundColorHueCursor" Width="22" Height="4" Margin="-2,-2,0,0" Fill="White" Stroke="Black" StrokeThickness="0.5"/>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <Button Content="👁️‍🗨️ Screen Picker" Click="ScreenPicker_Click" Tag="BackgroundColor"
                                                        Height="24" Margin="0,0,0,8" Style="{StaticResource ModernButton}" FontSize="10" Padding="5,2"/>
                                                <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,0,0,8"/>
                                                <TextBlock Text="Swatches" Foreground="#888888" FontSize="10" Margin="0,0,0,6" FontWeight="SemiBold" FontFamily="Segoe UI Variable Small"/>
                                                <UniformGrid Rows="4" Columns="6" Width="168" Height="112" x:Name="BackgroundColorGrid"/>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    
                                    <Label Grid.Column="4" Content="Opacity:" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="4" x:Name="BackgroundOpacitySlider" Minimum="0" Maximum="255" Value="0" 
                                            Margin="60,0,0,0" VerticalAlignment="Center" ValueChanged="OpacitySlider_ValueChanged"/>
                                </Grid>

                                <!-- Font Size -->
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Font Size (18-45):" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="FontSizeSlider" Minimum="18" Maximum="45" Value="32" 
                                            IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" ValueChanged="ControlChanged"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ElementName=FontSizeSlider, Path=Value}" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Audio Cues Card -->
                        <GroupBox Header="Audio Alerts" Foreground="#FF6124" BorderBrush="#333333" Margin="0,0,0,12" Padding="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Sound Type:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="SoundTypeComboBox" SelectionChanged="SoundTypeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Disabled (No Alert)" Tag="None"/>
                                        <ComboBoxItem Content="Game Alert Sound" Tag="BuiltIn"/>
                                        <ComboBoxItem Content="Custom Sound File" Tag="Custom"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Game Alert Options -->
                                <Grid x:Name="GameSoundPanel" Margin="0,0,0,8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Alert Sound ID:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="SoundIdComboBox" SelectionChanged="ControlChanged">
                                        <ComboBoxItem Content="Sound 1 (Standard)" Tag="1"/>
                                        <ComboBoxItem Content="Sound 2 (Medium Value)" Tag="2"/>
                                        <ComboBoxItem Content="Sound 3 (Exotic Value)" Tag="3"/>
                                        <ComboBoxItem Content="Sound 4" Tag="4"/>
                                        <ComboBoxItem Content="Sound 5" Tag="5"/>
                                        <ComboBoxItem Content="Sound 6 (High Tier Drop)" Tag="6"/>
                                        <ComboBoxItem Content="Sound 7" Tag="7"/>
                                        <ComboBoxItem Content="Sound 8" Tag="8"/>
                                        <ComboBoxItem Content="Sound 9" Tag="9"/>
                                        <ComboBoxItem Content="Sound 10" Tag="10"/>
                                        <ComboBoxItem Content="Sound 11" Tag="11"/>
                                        <ComboBoxItem Content="Sound 12" Tag="12"/>
                                        <ComboBoxItem Content="Sound 13" Tag="13"/>
                                        <ComboBoxItem Content="Sound 14" Tag="14"/>
                                        <ComboBoxItem Content="Sound 15" Tag="15"/>
                                        <ComboBoxItem Content="Sound 16" Tag="16"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Custom Sound Options -->
                                <Grid x:Name="CustomSoundPanel" Margin="0,0,0,8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Custom File (.wav):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="CustomSoundTextBox" Height="26" VerticalAlignment="Center" TextChanged="ControlChanged"/>
                                    <Button Grid.Column="2" Content="Browse..." Click="BrowseSound_Click" Height="26" Margin="5,0,0,0" Style="{StaticResource ModernButton}"/>
                                </Grid>

                                <CheckBox x:Name="MuteDefaultDropSoundCheckBox" Content="Mute Game Default Drop Sound (DisableDropSound)" 
                                          Foreground="White" Margin="0,5,0,0" Checked="ControlChanged" Unchecked="ControlChanged"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Minimap & Effects Card -->
                        <GroupBox Header="Minimap Icon &amp; Light Beams" Foreground="#FF6124" BorderBrush="#333333" Margin="0,0,0,5" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Minimap Icon Subgroup -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                    <Label Content="Minimap Shape:" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="MapShapeComboBox" SelectionChanged="Minimap_SelectionChanged" Margin="0,0,0,8">
                                        <ComboBoxItem Content="None" Tag=""/>
                                        <ComboBoxItem Content="Star" Tag="Star"/>
                                        <ComboBoxItem Content="Circle" Tag="Circle"/>
                                        <ComboBoxItem Content="Diamond" Tag="Diamond"/>
                                        <ComboBoxItem Content="Hexagon" Tag="Hexagon"/>
                                        <ComboBoxItem Content="Square" Tag="Square"/>
                                        <ComboBoxItem Content="Triangle" Tag="Triangle"/>
                                        <ComboBoxItem Content="Cross" Tag="Cross"/>
                                        <ComboBoxItem Content="Moon" Tag="Moon"/>
                                        <ComboBoxItem Content="Raindrop" Tag="Raindrop"/>
                                        <ComboBoxItem Content="Kite" Tag="Kite"/>
                                        <ComboBoxItem Content="Pentagon" Tag="Pentagon"/>
                                        <ComboBoxItem Content="UpsideDownHouse" Tag="UpsideDownHouse"/>
                                    </ComboBox>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <Label Content="Size:"/>
                                            <ComboBox x:Name="MapSizeComboBox" SelectionChanged="Minimap_SelectionChanged">
                                                <ComboBoxItem Content="Large (0)" Tag="0"/>
                                                <ComboBoxItem Content="Medium (1)" Tag="1"/>
                                                <ComboBoxItem Content="Small (2)" Tag="2"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <Label Content="Color:"/>
                                            <ComboBox x:Name="MapColorComboBox" SelectionChanged="Minimap_SelectionChanged">
                                                <ComboBoxItem Content="Red" Tag="Red"/>
                                                <ComboBoxItem Content="Orange" Tag="Orange"/>
                                                <ComboBoxItem Content="Yellow" Tag="Yellow"/>
                                                <ComboBoxItem Content="Green" Tag="Green"/>
                                                <ComboBoxItem Content="Blue" Tag="Blue"/>
                                                <ComboBoxItem Content="Cyan" Tag="Cyan"/>
                                                <ComboBoxItem Content="Purple" Tag="Purple"/>
                                                <ComboBoxItem Content="Pink" Tag="Pink"/>
                                                <ComboBoxItem Content="White" Tag="White"/>
                                                <ComboBoxItem Content="Brown" Tag="Brown"/>
                                                <ComboBoxItem Content="Grey" Tag="Grey"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- PlayEffect Beam Subgroup -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                                    <Label Content="Light Beam Effect:" FontWeight="SemiBold"/>
                                    <Label Content="Color:" Margin="0"/>
                                    <ComboBox x:Name="BeamColorComboBox" SelectionChanged="Beam_SelectionChanged" Margin="0,0,0,8">
                                        <ComboBoxItem Content="None" Tag=""/>
                                        <ComboBoxItem Content="Red" Tag="Red"/>
                                        <ComboBoxItem Content="Orange" Tag="Orange"/>
                                        <ComboBoxItem Content="Yellow" Tag="Yellow"/>
                                        <ComboBoxItem Content="Green" Tag="Green"/>
                                        <ComboBoxItem Content="Blue" Tag="Blue"/>
                                        <ComboBoxItem Content="Cyan" Tag="Cyan"/>
                                        <ComboBoxItem Content="Purple" Tag="Purple"/>
                                        <ComboBoxItem Content="Pink" Tag="Pink"/>
                                        <ComboBoxItem Content="White" Tag="White"/>
                                        <ComboBoxItem Content="Brown" Tag="Brown"/>
                                        <ComboBoxItem Content="Grey" Tag="Grey"/>
                                    </ComboBox>
                                    
                                    <CheckBox x:Name="BeamTempCheckBox" Content="Temporary Beam (Fades away)" 
                                              Foreground="White" Margin="0,8,0,0" Checked="Beam_SelectionChanged" Unchecked="Beam_SelectionChanged"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Live Ground Label Preview -->
            <Border Grid.Row="3" CornerRadius="8" Padding="15,20" BorderBrush="#262626" BorderThickness="1" Margin="0,5,0,10">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/LootPulse;component/Assets/ground_preview.png" Stretch="UniformToFill" Opacity="0.85"/>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Ground Item Label Preview:" Foreground="#888888" FontSize="10" Margin="0,0,0,5" FontFamily="Segoe UI Variable Small"/>
                        <Grid HorizontalAlignment="Left">
                            <!-- Simulated ground label item -->
                            <Border x:Name="PreviewLabelBorder" BorderThickness="1.5" CornerRadius="3" Padding="12,6">
                                <TextBlock x:Name="PreviewLabelText" Text="Sample Drop Highlight" FontWeight="Bold" FontFamily="Fontin, Arial, sans-serif"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Width="160">
                        <TextBlock Text="Map Icon &amp; Light Beam:" Foreground="#888888" FontSize="10" Margin="0,0,0,5" FontFamily="Segoe UI Variable Small"/>
                        <StackPanel Orientation="Horizontal">
                            <!-- Map Icon indicator -->
                            <Grid Width="24" Height="24" Margin="0,0,10,0">
                                <Ellipse x:Name="PreviewIconIndicator" Fill="Transparent" Stroke="#555555" StrokeThickness="1"/>
                                <TextBlock x:Name="PreviewIconChar" Text="✦" Foreground="#888888" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- Beam indicator -->
                            <Border x:Name="PreviewBeamIndicator" CornerRadius="2" Width="100" Height="24" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1">
                                <TextBlock x:Name="PreviewBeamText" Text="No Beam" Foreground="#666666" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dialog Footer -->
            <Grid Grid.Row="4" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="#888888" FontSize="11" Text="Styles will save to args/filter_presets.json and apply immediately." 
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Save &amp; Apply" Click="SaveApply_Click" Width="110" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Click="Cancel_Click" Width="80" Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
