<UserControl x:Class="LootPulse.Controls.MarketPulseGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="400"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <!-- ═══════════════════════════════════════════════════════════════
         MARKET PULSE GRAPH — Moonshot #1
         "The Heartbeat of the Economy"

         An animated EKG/heartbeat line that scrolls continuously.
         Its rhythm reflects market volatility:
           - Calm:    slow, steady waves
           - Active:  faster, taller spikes
           - Spike:   single major peak (price alert)
           - Flatline: no data / disconnected

         The line uses PoeGold stroke with a PoeOrange glow trail.
         ═══════════════════════════════════════════════════════════════ -->

    <Grid ClipToBounds="True">
        <!-- Background track (faint baseline) -->
        <Path x:Name="BaselinePath"
              Stroke="{DynamicResource Surface3}"
              StrokeThickness="0.5"
              Data="M 0,20 L 400,20"
              Opacity="0.5"/>

        <!-- Main EKG wave — scrolling continuously left -->
        <Canvas x:Name="WaveCanvas" ClipToBounds="True">
            <Path x:Name="EkgPath"
                  Stroke="{DynamicResource PulseSecondary}"
                  StrokeThickness="1.5"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Effect="{DynamicResource GoldGlowEffect}">
                <Path.Data>
                    <PathGeometry x:Name="EkgGeometry"/>
                </Path.Data>
                <Path.RenderTransform>
                    <TranslateTransform x:Name="WaveTranslate" X="0"/>
                </Path.RenderTransform>
            </Path>

            <!-- Orange glow trail (slightly behind, thicker, blurred) -->
            <Path x:Name="EkgGlowPath"
                  Stroke="{DynamicResource PulsePrimary}"
                  StrokeThickness="3"
                  StrokeLineJoin="Round"
                  Opacity="0.4">
                <Path.Data>
                    <PathGeometry x:Name="EkgGlowGeometry"/>
                </Path.Data>
                <Path.RenderTransform>
                    <TranslateTransform x:Name="GlowTranslate" X="0"/>
                </Path.RenderTransform>
                <Path.Effect>
                    <BlurEffect Radius="6"/>
                </Path.Effect>
            </Path>
        </Canvas>

        <!-- Status indicator dot (pulses with the heartbeat) -->
        <Ellipse x:Name="StatusDot"
                 Width="6" Height="6"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="4,0,0,0"
                 Fill="{DynamicResource PulsePrimary}">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="StatusDotScale" CenterX="3" CenterY="3"/>
            </Ellipse.RenderTransform>
            <Ellipse.Effect>
                <DropShadowEffect x:Name="StatusDotGlow"
                                  Color="{StaticResource PulsePrimaryColor}"
                                  BlurRadius="8"
                                  ShadowDepth="0"
                                  Opacity="0.8"/>
            </Ellipse.Effect>
        </Ellipse>
    </Grid>

</UserControl>
