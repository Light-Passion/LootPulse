<UserControl x:Class="LootPulse.Controls.MarketPulseGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="400"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             SizeChanged="UserControl_SizeChanged">

    <!-- ═══════════════════════════════════════════════════════════════
         MARKET PULSE GRAPH — Moonshot #1
         "The Heartbeat of the Economy"
         ═══════════════════════════════════════════════════════════════ -->

    <Grid ClipToBounds="True" Background="#18FF6124">
        <!-- Debug: faint orange tint so we can see the control bounds -->
        <!-- Main EKG wave — PoeGold (#E5B560) scrolling left -->
        <Path x:Name="EkgPath"
              Stroke="#E5B560"
              StrokeThickness="1.5"
              StrokeLineJoin="Round"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round">
            <Path.RenderTransform>
                <TranslateTransform x:Name="WaveTranslate" X="0"/>
            </Path.RenderTransform>
        </Path>

        <!-- Orange glow trail (#FF6124, thicker, blurred) -->
        <Path x:Name="EkgGlowPath"
              Stroke="#FF6124"
              StrokeThickness="3"
              StrokeLineJoin="Round"
              Opacity="0.35">
            <Path.RenderTransform>
                <TranslateTransform x:Name="GlowTranslate" X="0"/>
            </Path.RenderTransform>
            <Path.Effect>
                <BlurEffect Radius="6"/>
            </Path.Effect>
        </Path>

        <!-- Status indicator dot (pulses with the heartbeat) -->
        <Ellipse x:Name="StatusDot"
                 Width="6" Height="6"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="2,0,0,0"
                 Fill="#FF6124">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="StatusDotScale" CenterX="3" CenterY="3"/>
            </Ellipse.RenderTransform>
            <Ellipse.Effect>
                <DropShadowEffect x:Name="StatusDotGlow"
                                  Color="#FF6124"
                                  BlurRadius="8"
                                  ShadowDepth="0"
                                  Opacity="0.8"/>
            </Ellipse.Effect>
        </Ellipse>
    </Grid>

</UserControl>
