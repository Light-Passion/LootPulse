<Window x:Class="LootPulse.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LootPulse HUD"
        Height="160" Width="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- HUD Outer Border — "Floating Obsidian Panel" with PoeGold accent -->
        <Border x:Name="HudOuterBorder" CornerRadius="10" BorderBrush="#3D3D3D" BorderThickness="1.5" Background="#F2121212">
            <Viewbox x:Name="HudViewbox" Stretch="Uniform" Margin="8">
                <Grid Width="260" Height="152">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>  <!-- Header -->
                        <RowDefinition Height="14"/>  <!-- EKG Line -->
                        <RowDefinition Height="*"/>   <!-- Main Info -->
                        <RowDefinition Height="36"/>  <!-- Currency Ticker (2 rows of 3) -->
                        <RowDefinition Height="16"/>  <!-- Status Footer -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Header — Hex badge + Zone name + Drag notice -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Hexagonal status badge -->
                            <Path Width="10" Height="10" Fill="#FF6124" Margin="0,0,6,0"
                                  Data="M5,0 L10,3 L10,7 L5,10 L0,7 L0,3 Z"/>
                            <TextBlock Text="LOOTPULSE" Foreground="#888888" FontSize="9" FontWeight="Bold"
                                       FontFamily="Fontin"/>
                        </StackPanel>
                        <TextBlock x:Name="DragNoticeText" Text="[Drag to Position]" Foreground="#555555" FontSize="8"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Visible"/>
                    </Grid>

                    <!-- Row 1: EKG Pulse Line — animated heartbeat trace -->
                    <Canvas Grid.Row="1" Height="12" ClipToBounds="True" Margin="0,1,0,0">
                        <!-- Glow trail — duplicated waveform (0→520) for seamless loop -->
                        <Path x:Name="HudEkgGlow" Stroke="#FF6124" StrokeThickness="2.5" Opacity="0.3"
                              StrokeLineJoin="Round" Data="M 0,6 L 40,6 L 48,2 L 52,10 L 56,6 L 100,6 L 108,3 L 112,9 L 116,6 L 160,6 L 168,2 L 172,10 L 176,6 L 220,6 L 228,3 L 232,9 L 236,6 L 260,6 L 300,6 L 308,2 L 312,10 L 316,6 L 360,6 L 368,3 L 372,9 L 376,6 L 420,6 L 428,2 L 432,10 L 436,6 L 480,6 L 488,3 L 492,9 L 496,6 L 520,6">
                            <Path.Effect>
                                <BlurEffect Radius="4"/>
                            </Path.Effect>
                            <Path.RenderTransform>
                                <TranslateTransform x:Name="HudEkgGlowTransform" X="0"/>
                            </Path.RenderTransform>
                        </Path>
                        <!-- Main EKG line — duplicated waveform (0→520) for seamless loop -->
                        <Path x:Name="HudEkgPath" Stroke="#E5B560" StrokeThickness="1.2"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 0,6 L 40,6 L 48,2 L 52,10 L 56,6 L 100,6 L 108,3 L 112,9 L 116,6 L 160,6 L 168,2 L 172,10 L 176,6 L 220,6 L 228,3 L 232,9 L 236,6 L 260,6 L 300,6 L 308,2 L 312,10 L 316,6 L 360,6 L 368,3 L 372,9 L 376,6 L 420,6 L 428,2 L 432,10 L 436,6 L 480,6 L 488,3 L 492,9 L 496,6 L 520,6">
                            <Path.RenderTransform>
                                <TranslateTransform x:Name="HudEkgTransform" X="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>

                    <!-- Row 2: Main Info — Zone, Level, Character -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="0,3,0,3">
                        <TextBlock x:Name="HudZoneText" Text="Lioneye's Watch" Foreground="White" FontSize="15"
                                   FontWeight="Bold" TextTrimming="CharacterEllipsis" FontFamily="Fontin"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="LVL " Foreground="#E5B560" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Fontin"/>
                            <TextBlock x:Name="HudLevelText" Text="1" Foreground="#E5B560" FontSize="11"
                                       FontWeight="Bold" FontFamily="Fontin"/>
                            <TextBlock x:Name="HudCharNameText" Text="  (Exile)" Foreground="#AAAAAA" FontSize="11"
                                       Margin="0,0,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Row 3: Currency Ticker — dynamic, up to 6 items in 2 rows of 3 -->
                    <Border Grid.Row="3" Background="{DynamicResource Surface1}" CornerRadius="4" Padding="4,2" Margin="0,0,0,1">
                        <ItemsControl x:Name="HudCurrencyPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2,0">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextTertiary}" FontSize="8.5"
                                                   FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value}" Foreground="{DynamicResource PulseSecondary}" FontSize="8.5"
                                                   FontWeight="Medium" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"
                                                   Margin="2,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Row 4: Status Footer -->
                    <TextBlock Grid.Row="4" x:Name="HudStatusText" Text="Overlay Active" Foreground="#666666"
                               FontSize="8.5" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"
                               FontFamily="Fontin"/>
                </Grid>
            </Viewbox>
        </Border>
    </Grid>
</Window>
