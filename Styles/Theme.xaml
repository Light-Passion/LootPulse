<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════
         LOOTPULSE DESIGN TOKEN SYSTEM
         "The Heartbeat of the Economy" — Obsidian + Pulse + Glow
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Surface Scale (7 depth levels, blue-tinted obsidian) ─────── -->
    <Color x:Key="BackgroundColor">#0E0E0F</Color>
    <Color x:Key="Surface0Color">#15151A</Color>
    <Color x:Key="Surface1Color">#1C1C22</Color>
    <Color x:Key="Surface2Color">#24242C</Color>
    <Color x:Key="Surface3Color">#2E2E38</Color>
    <Color x:Key="Surface4Color">#38384A</Color>
    <Color x:Key="OverlayColor">#0A0A0C</Color>

    <SolidColorBrush x:Key="Background" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="Surface0"  Color="{StaticResource Surface0Color}"/>
    <SolidColorBrush x:Key="Surface1"  Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Surface2"  Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="Surface3"  Color="{StaticResource Surface3Color}"/>
    <SolidColorBrush x:Key="Surface4"  Color="{StaticResource Surface4Color}"/>
    <SolidColorBrush x:Key="Overlay"   Color="{StaticResource OverlayColor}" Opacity="0.8"/>

    <!-- Legacy aliases (for gradual migration — map old names to new tokens) -->
    <SolidColorBrush x:Key="BgDark"    Color="{StaticResource Surface0Color}"/>
    <SolidColorBrush x:Key="BgPanel"   Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="PoeOrange" Color="#FF6124"/>
    <SolidColorBrush x:Key="PoeGold"    Color="#E5B560"/>

    <!-- ── Accent System ────────────────────────────────────────────── -->
    <Color x:Key="PulsePrimaryColor">#FF6124</Color>
    <Color x:Key="PulseSecondaryColor">#E5B560</Color>
    <Color x:Key="PulseHotColor">#FF8A3D</Color>
    <Color x:Key="PulseDeepColor">#CC4A18</Color>

    <SolidColorBrush x:Key="PulsePrimary"   Color="{StaticResource PulsePrimaryColor}"/>
    <SolidColorBrush x:Key="PulseSecondary" Color="{StaticResource PulseSecondaryColor}"/>
    <SolidColorBrush x:Key="PulseHot"       Color="{StaticResource PulseHotColor}"/>
    <SolidColorBrush x:Key="PulseDeep"      Color="{StaticResource PulseDeepColor}"/>
    <SolidColorBrush x:Key="PulseGlow"      Color="{StaticResource PulsePrimaryColor}" Opacity="0.30"/>
    <SolidColorBrush x:Key="GoldGlow"        Color="{StaticResource PulseSecondaryColor}" Opacity="0.25"/>

    <!-- ── Semantic Colors ──────────────────────────────────────────── -->
    <Color x:Key="SuccessColor">#4ADE80</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>
    <Color x:Key="DangerColor">#F87171</Color>
    <Color x:Key="InfoColor">#60A5FA</Color>

    <!-- Flash tints for ticker cell price-change animation (8% opacity) -->
    <Color x:Key="SuccessFlashColor">#144ADE80</Color>
    <Color x:Key="DangerFlashColor">#14F87171</Color>

    <SolidColorBrush x:Key="Success"  Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="Warning"  Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="Danger"    Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="Info"      Color="{StaticResource InfoColor}"/>

    <!-- ── Text Scale ────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimaryColor">#F0F0F0</Color>
    <Color x:Key="TextSecondaryColor">#AAAAAA</Color>
    <Color x:Key="TextTertiaryColor">#6B6B7A</Color>
    <Color x:Key="TextInverseColor">#0E0E0F</Color>
    <Color x:Key="TextAccentColor">#E5B560</Color>

    <SolidColorBrush x:Key="TextPrimary"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiary"  Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextInverse"    Color="{StaticResource TextInverseColor}"/>
    <SolidColorBrush x:Key="TextAccent"     Color="{StaticResource TextAccentColor}"/>

    <!-- ── Misc Grays (for gradual migration) ───────────────────────── -->
    <SolidColorBrush x:Key="BorderSubtle"  Color="#38384A"/>
    <SolidColorBrush x:Key="BorderDefault" Color="#444450"/>

    <!-- ═══════════════════════════════════════════════════════════════
         SPACING SCALE (4px base)
         ═══════════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="Space0">2</sys:Double>
    <sys:Double x:Key="Space1">4</sys:Double>
    <sys:Double x:Key="Space2">8</sys:Double>
    <sys:Double x:Key="Space3">12</sys:Double>
    <sys:Double x:Key="Space4">16</sys:Double>
    <sys:Double x:Key="Space5">20</sys:Double>
    <sys:Double x:Key="Space6">24</sys:Double>
    <sys:Double x:Key="Space7">32</sys:Double>
    <sys:Double x:Key="Space8">48</sys:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         BORDER RADIUS SYSTEM
         ═══════════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusSmall">4,4,4,4</CornerRadius>
    <sys:Double x:Key="RadiusSmallValue">4</sys:Double>
    <CornerRadius x:Key="RadiusMedium">8,8,8,8</CornerRadius>
    <sys:Double x:Key="RadiusMediumValue">8</sys:Double>
    <CornerRadius x:Key="RadiusLarge">12,12,12,12</CornerRadius>
    <sys:Double x:Key="RadiusLargeValue">12</sys:Double>
    <CornerRadius x:Key="RadiusXLarge">16,16,16,16</CornerRadius>
    <sys:Double x:Key="RadiusXLargeValue">16</sys:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         EFFECTS
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Subtle drop shadow for cards/panels (depth = 4, downward) -->
    <DropShadowEffect x:Key="CardShadow"
                      Color="#000000"
                      BlurRadius="20"
                      ShadowDepth="4"
                      Direction="270"
                      Opacity="0.4"/>

    <!-- PoeOrange glow for active/hover elements -->
    <DropShadowEffect x:Key="PulseGlowEffect"
                      Color="{StaticResource PulsePrimaryColor}"
                      BlurRadius="12"
                      ShadowDepth="0"
                      Opacity="0.6"/>

    <!-- PoeGold glow for data/economy indicators -->
    <DropShadowEffect x:Key="GoldGlowEffect"
                      Color="{StaticResource PulseSecondaryColor}"
                      BlurRadius="8"
                      ShadowDepth="0"
                      Opacity="0.5"/>

</ResourceDictionary>
