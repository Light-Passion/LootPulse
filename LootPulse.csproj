<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <!-- Exclude the test project folder from compilation in the main app -->
    <Compile Remove="LootPulse.Tests\**" />
    <EmbeddedResource Remove="LootPulse.Tests\**" />
    <None Remove="LootPulse.Tests\**" />
    <Page Remove="LootPulse.Tests\**" />
  </ItemGroup>

</Project>
